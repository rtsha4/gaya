{
  "id": "example-lottie",
  "name": "Lottie Sample (test)",
  "version": "1.0.0",
  "renderer": "lottie",
  "size": { "width": 200, "height": 200 },
  "bubble": {
    "anchor": "top-right"
  },
  "defaultState": "idle",
  "fallbackState": "idle",
  "states": {
    "idle": "lottie/idle.json",
    "thinking": "lottie/thinking.json",
    "working": "lottie/working.json",
    "waiting": "lottie/waiting.json",
    "done": "lottie/done.json",
    "error": "lottie/error.json"
  }
}
